# RevOps Command Center — environment template.
# Copy to .env and fill in real values. .env is gitignored; never commit it.

# Anthropic (MEDDPICC scoring engine)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Model used for scoring. Sonnet 5 is a good accuracy/cost balance for this task.
MEDDPICC_MODEL=claude-sonnet-5

# Supabase (state layer)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# HubSpot Service Key (Week 8 CRM writeback) — Bearer token.
HUBSPOT_TOKEN=pat-na1-xxxxxxxx

# Slack (Week 8 delivery) — Bot User OAuth Token for the "RevOps Command Center" app.
SLACK_BOT_TOKEN=xoxb-xxxxxxxx
SLACK_CHANNEL=#revops-command-center
